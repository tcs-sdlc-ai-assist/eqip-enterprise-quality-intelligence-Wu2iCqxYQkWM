# Environment Configuration Template
# Copy this file to .env and update values as needed.
# All client-exposed variables MUST be prefixed with VITE_

# Application title displayed in the browser tab and UI header
VITE_APP_TITLE=eQIP Quality Intelligence

# Feature flags (set to "true" or "false")
VITE_FEATURE_EXPORT_CSV=true
VITE_FEATURE_DARK_MODE=false